<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="view.Controller">
    <children>
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <children>
                <Label text="Loan Amount">
               <font>
                  <Font name="System Bold" size="13.0" />
               </font></Label>
                <TextField fx:id="txtAmount" prefWidth="100.0" />
                <Label text="Number of Years">
               <font>
                  <Font name="System Bold" size="13.0" />
               </font></Label>
                <TextField fx:id="txtYears" prefWidth="50.0" />
                <Button fx:id="btnShowTable" mnemonicParsing="false" onAction="#handleShowTable" text="Show Table">
               <font>
                  <Font name="System Bold" size="13.0" />
               </font></Button>
            </children>
        </HBox>
        <TextArea fx:id="txtAreaResults" editable="false" prefHeight="300.0" prefWidth="500.0">
            <font>
                <Font name="Monospaced Regular" size="13.0" />
            </font>
        </TextArea>
    </children>
    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
    </padding>
</VBox>
